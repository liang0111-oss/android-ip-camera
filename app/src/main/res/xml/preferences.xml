<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory
        android:title="Authentication">
        <EditTextPreference
            android:key="username"
            android:title="Username"
            android:defaultValue=""
            android:singleLine="true" />
        <EditTextPreference
            android:key="password"
            android:title="Password"
            android:defaultValue=""
            android:inputType="textPassword"
            android:singleLine="true" />
    </PreferenceCategory>

    <PreferenceCategory android:title="Connection Settings">
        <SwitchPreferenceCompat
            android:key="enable_https"
            android:title="Enable HTTPS"
            android:summary="Use TLS encryption. Disable for HTTP (no certificate needed)"
            android:defaultValue="true" />
        <EditTextPreference
            android:key="stream_port"
            android:title="Port"
            android:summary="Server port (default: 6666)"
            android:defaultValue="6666"
            android:inputType="number"
            android:singleLine="true" />
    </PreferenceCategory>

    <PreferenceCategory
        android:key="certificate_settings"
        android:title="Certificate Settings">
        <Preference
            android:key="certificate_path"
            android:title="Custom TLS Certificate" android:summary="Select your own certificate" android:persistent="true" />
        <EditTextPreference
            android:key="certificate_password"
            android:title="Certificate Password"
            android:summary="Optional password for the TLS certificate"
            android:persistent="true"
            android:inputType="textPassword" />
        <Preference
            android:key="test_certificate"
            android:title="Test Certificate Setup"
            android:summary="Validate your certificate configuration"
            android:persistent="false" />
    </PreferenceCategory>
</PreferenceScreen>
